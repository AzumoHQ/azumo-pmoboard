# Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Optional protection for POST /api/refresh
PMO_REFRESH_TOKEN="change-me"

# Optional server-side password for notes stored in Neon.
# If omitted, the dashboard keeps using browser localStorage with the legacy password.
PMO_NOTES_PASSWORD="change-me"

# Jira Cloud
JIRA_BASE_URL="https://your-company.atlassian.net"
JIRA_EMAIL="you@example.com"
JIRA_API_TOKEN="jira-api-token"
JIRA_JQL="project = AA"

# EazyBI
EAZYBI_URL="https://your-company.eazybi.com"
EAZYBI_EMAIL="you@example.com"
EAZYBI_ACCOUNT_ID="account-id"
EAZYBI_TOKEN="eazybi-token"
EAZYBI_REPORT_ID="123"
