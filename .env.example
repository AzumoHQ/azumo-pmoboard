# Neon
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Optional protection for POST /api/refresh
# Kept as fallback for scripts/cron. Human refresh uses PMO users + session cookie.
PMO_REFRESH_TOKEN="change-me"

# Optional session duration for PMO user login.
PMO_SESSION_DAYS="7"

# Optional server-side password for notes stored in Neon.
# If omitted, the dashboard keeps using browser localStorage with the legacy password.
PMO_NOTES_PASSWORD="change-me"

# Jira Cloud
JIRA_BASE_URL="https://your-company.atlassian.net"
JIRA_EMAIL="you@example.com"
JIRA_API_TOKEN="jira-api-token"
JIRA_JQL="project = AA"
# Optional override if Jira field discovery cannot find the AA Epic field
# named "Position - Assignee". The dashboard uses this Epic field as the
# only source for visible Position.
JIRA_EPIC_POSITION_FIELD="customfield_XXXXX"

# EazyBI
EAZYBI_URL="https://your-company.eazybi.com"
EAZYBI_PUBLIC_URL="https://your-company.eazybi.com"
EAZYBI_EMAIL="you@example.com"
EAZYBI_ACCOUNT_ID="account-id"
EAZYBI_TOKEN="eazybi-token"
EAZYBI_REPORT_ID="123"
EAZYBI_DEFAULT_ACCOUNT_ID="123"
EAZYBI_DEFAULT_REPORT_ID="456"
EAZYBI_BENCH_BY_MONTH_REPORT_ID="456"
EAZYBI_BENCH_BY_MONTH_ACCOUNT_ID="123"
EAZYBI_UTILIZATION_BILLING_ACCOUNT_ID="123"
EAZYBI_UTILIZATION_BILLING_REPORT_ID="456"
EAZYBI_UTILIZATION_BILLING_TOKEN="embed-token-stored-in-vercel"
EAZYBI_INTERNAL_PROJECTS_ACCOUNT_ID="123"
EAZYBI_INTERNAL_PROJECTS_REPORT_ID="456"
EAZYBI_INTERNAL_PROJECTS_TOKEN="embed-token-stored-in-vercel"
EAZYBI_NEW_SEARCHES_ACCOUNT_ID="123"
EAZYBI_NEW_SEARCHES_REPORT_ID="456"
EAZYBI_NEW_SEARCHES_TOKEN="embed-token-stored-in-vercel"

# Harvest
# Used by /api/refresh to store active Harvest projects/files and user assignments,
# then compare Harvest access vs Jira active assignments.
HARVEST_ACCOUNT_ID="123456"
HARVEST_ACCESS_TOKEN="pat_xxx_or_oauth_token"
HARVEST_USER_AGENT="PMO Dashboard (pmo@example.com)"

# Daily QA automation
# Vercel cron runs /api/cron-daily-qa every day at 12:00 UTC = 9:00 AM Argentina.
PMO_QA_TIMEZONE="America/Argentina/Mendoza"
PMO_DASHBOARD_URL="https://pmoboard.vercel.app"
PMO_QA_EMAIL_TO="pmo@example.com"
PMO_QA_EMAIL_FROM="PMO Dashboard <pmo@example.com>"
# Configure one provider:
RESEND_API_KEY="re_xxx"
# SENDGRID_API_KEY="SG.xxx"

# Slack due-today alert for #assignments-hub.
# Configure either a bot token + channel ID, or an incoming webhook.
SLACK_BOT_TOKEN="xoxb-..."
SLACK_ASSIGNMENTS_CHANNEL_ID="C1234567890"
# SLACK_ASSIGNMENTS_WEBHOOK_URL="https://hooks.slack.com/services/..."
# Optional map so PM names become Slack mentions: {"Jennifer Greyling":"U123","jennifer@example.com":"U123"}
SLACK_USER_MAP_JSON="{}"
# Optional token used by the generated Slack image URL.
PMO_PUBLIC_DUE_CARD_TOKEN="change-me"
