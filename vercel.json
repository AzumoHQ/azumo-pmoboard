{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/pmo-data.json",
      "destination": "/api/dashboard"
    },
    {
      "source": "/pmo-dashboard.html",
      "destination": "/"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-snapshot",
      "schedule": "0 12 * * *"
    }
  ]
}
